local ffi = require("ffi")

FuRegisterClass("RalfAudioSpectrum", CT_SourceTool, {
    REGS_Name               = "Ralf Audio Spectrum",
    REGS_OpDescription      = "Ralf Audio Spectrum",
	REGS_Category = "Generator",
	REGS_OpIconString = "fSc",

	REG_Source_GlobalCtrls = true,
	REG_Source_SizeCtrls = true,
	REG_Source_AspectCtrls = true,
	REG_Source_DepthCtrls = true,

	REG_TimeVariant = true,
    REG_NoPreCalcProcess = true,
	})


-- ///// STRUCTS

-- https://en.wikipedia.org/wiki/WAV#WAV_file_header
ffi.cdef[[
    // Struct of the outer RIFF chunk
    typedef struct {
        char     chunkID[4];    // "RIFF"
        uint32_t chunkSize;     // File size minus 8
        char     format[4];     // "WAVE"
    } WAV_RIFF_Header;

    // Struct of the first mandatory fmt chunk
    typedef struct {
        char     chunkID[4];    // "fmt "
        uint32_t chunkSize;
        uint16_t audioFormat;   // 1 = PCM
        uint16_t numChannels;
        uint32_t sampleRate;
        uint32_t bytePerSec;    // sampleRate * bytesPerBlock
        uint16_t bytesPerBlock; // numChannels * bitsPerSample / 8
        uint16_t bitsPerSample; // 8 or 16; we only support 16
    } WAV_FMT_Chunk;

    // Struct of any RIFF chunk
    typedef struct {
        char     chunkID[4];    // "data" is the only we need after "fmt "
        uint32_t chunkSize;
    } WAV_Chunk_Header;
]]

-- ///////////// Constants ///////////////
-- LuaJit will optimize these if they are not modified.

local MAX_INT16 = 32768

local WaveformShape_SignedWave = 0
local WaveformShape_HalfWave = 1
local WaveformShape_MirrorWave = 2

-- 9 standard octave bands tracking frequencies up to ~16kHz
local EQ_BANDS = {
    { name = "Sub-Bass", f0 = 31.25 },
    { name = "Bass",     f0 = 62.5  },
    { name = "Low-Mid",  f0 = 125.0 },
    { name = "Mid",      f0 = 250.0 },
    { name = "Mid-High", f0 = 500.0 },
    { name = "Presence", f0 = 1000.0},
    { name = "Brilliance",f0 = 2000.0},
    { name = "Highs 1",  f0 = 4000.0},
    { name = "Highs 2",  f0 = 8000.0},
}

-- ///////////// GLOBALS ///////////////
-- Globals persist between Process calls once the Fuse plugin is loaded.
-- Exhausting memory will likely crash DaVinci.

_globalStart = 0

_loadedFileName = ""
_loadedFileStatus = ""
_loadedWavFormat = nil      -- an FFI struct of WAV_FMT_Chunk type
_loadedSampleRate = 0       -- the value of _loadedWavFormat.sampleRate, for easier access
-- WARNING: FFI native buffer of signed int16.
-- Use _loadedWavSamples[index] to get signed int16 values.
-- Use numLoadedWavSamples() to get number of samples (0 means no data available).
_loadedWavSamples = nil
_wavOffsetSeconds = -1

_vuMeterLastFrameIndex = -1
_vuMeterDbValue = -96.0     -- -96 dBFS is the theorical minimum for an audio CD 44100 Hz 16-bit signal
_vuMeterLinearValue = 0     -- a [0..1] loudness value
_vuMeterLinearMin = 1       -- a [0..1] loudness value
_vuMeterLinearMax = 0       -- a [0..1] loudness value

_eqBandsLastFrameIndex = -1
_eqBands = nil              -- initialized by _initEqBands(), filled by _computeEqBands()


-- Note for self:
-- Right now we load the entire WAV mono samples in memory. If we wanted to load
-- more than memory could handle, we could change _loadedWavSamples to be loaded
-- from disk in large segments (e.g. 10 MB) with a moving window. Currently, the
-- typical music I'd process is 5-10 minutes long. 10 min at 48 kHz mono is about
-- 29 million samples, or 58 MB. That's perfectly fine on a 32 GB machine which
-- typically reports 12 GB free -- that's enough for 37 hours of mono 16-bit samples.


-- /////////////////////////////////////


function Create()
    print("@@ Create")

    _inWavFile = self:AddInput("WAV File", "WavFile", {
        LINKID_DataType = "Text",
        INPID_InputControl =  "FileControl",
        FC_ClipBrowse = false,
        INP_DoNotifyChanged  = true,
        INP_External = false,
        FCS_FilterString = "WAV-Files (*.wav)|*.wav|"
        })

    _inReload = self:AddInput("Reload Audio File", "ReloadAudio", {
        INPID_InputControl =  "ButtonControl",
        INP_DoNotifyChanged  = true,
        INP_External = false,
        ICD_Width = 0.5,
        BTNCS_Execute = "tool.ScriptReload[fu.TIME_UNDEFINED] = 1",
        })

    _inWavOffsetSeconds = self:AddInput("Offset (seconds)", "PlaybackOffsetSeconds", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ScrewControl",
        INP_DoNotifyChanged  = true,
        INP_Default = 0.0,
        INP_MinScale = 0.0,
        INP_MaxScale = 10.0,
        })

    -- INFO printfs
    self:AddInput(string.rep("_", 52), "InfoSeparator", {
        LINKID_DataType = "Text",
        INPID_InputControl = "LabelControl",
        INP_External = false,
        INP_Passive = true,
        })

    _inInfoFileName = self:AddInput("No Audio loaded", "InfoFileName", {
        LINKID_DataType    = "Text",
        INPID_InputControl = "LabelControl",
        INP_External       = false,
        INP_Passive        = true,
        ICD_Width          = 1,
        })

    _inInfoFileStatus = self:AddInput("Please select a file first", "InfoFileStatus", {
        LINKID_DataType    = "Text",
        INPID_InputControl = "LabelControl",
        INP_External       = false,
        INP_Passive        = true,
        ICD_Width          = 1,
        })


    -- VU Meter Parameters

    self:AddControlPage("VU Meter")

    _inVuMeterDurationSeconds = self:AddInput("Samples (seconds)", "VuMeterDurationSeconds", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.1,
        INP_MaxScale = 2.0,
        INP_Default = 1,
        ICD_Center = 1,
        })

    -- SmoothingFactor is the % of the old value to keep.
    -- Nitpick: It's not a % if the value is in the [0..1] range, and I don't even care!
    -- SmoothingFactor == 0 ==> 100% of the old value is used, the new value is never used.
    -- SmoothingFactor == 1 ==> 0% of the old value is used, the new value is instantly used.
    -- 0.1 (10%) makes a good fast change, 0.5 (50%) makes it a very slow progressive change.
    _inVuMeterSmoothingFactorDown = self:AddInput("Smoothing % Down", "VuMeterSmoothingFactorDown", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.2,
        ICD_Center = 1,
        })

    _inVuMeterSmoothingFactorUp = self:AddInput("Smoothing % Up", "VuMeterSmoothingFactorUp", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.05,
        ICD_Center = 1,
        })

    _inVuMeterLiveMonitor = self:AddInput("Live Monitor", "VuMeterLiveMonitor", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_DoNotifyChanged = true,
        INP_External = false,
        INP_Default = 1,
        })

    _inInfoVuMeterLiveMonitor = self:AddInput("Monitor: n/a", "InfoVuMeterLiveMonitor", {
        LINKID_DataType    = "Text",
        INPID_InputControl = "LabelControl",
        INP_External       = false,
        INP_Passive        = true,
        ICD_Width          = 1,
        })

    _inInfoVuMeterLiveMonitor2 = self:AddInput("Monitor: n/a", "InfoVuMeterLiveMonitor2", {
        LINKID_DataType    = "Text",
        INPID_InputControl = "LabelControl",
        INP_External       = false,
        INP_Passive        = true,
        ICD_Width          = 1,
        })

    -- Waveform Parameters

    self:AddControlPage("Waveform")

    _inDisplayWaveform = self:AddInput("Display Waveform", "WaveformDisplay", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_DoNotifyChanged = true,
        INP_Default = 1,
        })

    -- How many seconds to display in the image width (centered)
    _inWaveformSecondsX = self:AddInput("Horiz Duration (seconds)", "WaveformSecondsX", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ScrewControl",
        INP_Default = 1.0,
        INP_MinScale = 0.0,
        INP_MaxScale = 10.0,
        })

    _inWaveformCorner1Point = self:AddInput("Top Left Crop", "WaveformCorner1Point", {
        LINKID_DataType = "Point",
        INPID_InputControl = "OffsetControl",
        INPID_PreviewControl = "CrosshairControl", -- Display Control
        INP_DefaultX = 0.05,
        INP_DefaultY = 0.70,
        })

    _inWaveformCorner2Point = self:AddInput("Bottom Right Crop", "WaveformCorner2Point", {
        LINKID_DataType = "Point",
        INPID_InputControl = "OffsetControl",
        INPID_PreviewControl = "CrosshairControl",
        INP_DefaultX = 0.95,
        INP_DefaultY = 0.30,
        })

    -- inWaveformAmpliFactor is the % to _reduce_ the amplitude when the vu-meter is 0.
    -- inWaveformAmpliFactor == 0 --> waveform height never changes.
    -- inWaveformAmpliFactor == 1 --> wafeform height is 100% proportional to vu-meter value.
    _inWaveformAmpliFactor = self:AddInput("Amplitude Factor", "WaveformAmpliFactor", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinAllowed = 0.0,
        INP_MaxAllowed = 1.0,
        INP_Default = 0.75,
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        ICD_Center = 1,
        })

    _inDisplayAmplitude = self:AddInput("Display Amplitude", "WaveformDisplayAmplitude", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_DoNotifyChanged = true,
        INP_Default = 1,
        })

    _inWaveformShape = self:AddInput("Shape", "WaveformShape", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Default = 0.0,
        INP_Integer = true,
        ICD_Width = 1,
        { CCS_AddString = "Signed Wave", },             -- WaveformShape_SignedWave
        { CCS_AddString = "Half Wave (filled)", },      -- WaveformShape_HalfWave
        { CCS_AddString = "Mirror Wave (filled)", },    -- WaveformShape_MirrorWave
        CC_LabelPosition = "Horizontal",
        })

    _inWaveformStrokeWidth = self:AddInput("Stroke Width", "WaveformStrokeWidth", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinAllowed = 0.0,
        INP_MinScale = 0.0,
        INP_MaxScale = 0.01,
        INP_Default = 0.002,
        ICD_Center = 0.001,
        })

    _inWaveformFillAlpha = self:AddInput("Fill Alpha", "WaveformFillAlpha", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.5,
        ICD_Center = 1,
        })



    -- Graphic Equalizer Bars Parameters

    self:AddControlPage("EQ Bars")

    _inDisplayEqBars = self:AddInput("Display EQ Bars", "EqDisplay", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_DoNotifyChanged = true,
        INP_Default = 1,
        })

    _inEqDurationSeconds = self:AddInput("Samples (seconds)", "EqDurationSeconds", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.1,
        INP_MaxScale = 2.0,
        INP_Default = 1,
        ICD_Center = 1,
        })

    -- See SmoothingFactor explanation for Vu Meter.
    _inEqSmoothingFactorDown = self:AddInput("Smoothing % Down", "EqSmoothingFactorDown", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.2,
        ICD_Center = 1,
        })

    _inEqSmoothingFactorUp = self:AddInput("Smoothing % Up", "EqSmoothingFactorUp", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.05,
        ICD_Center = 1,
        })

    _inEqCorner1Point = self:AddInput("Top Left Crop", "EqCorner1Point", {
        LINKID_DataType = "Point",
        INPID_InputControl = "OffsetControl",
        INPID_PreviewControl = "CrosshairControl", -- Display Control
        INP_DefaultX = 0.05,
        INP_DefaultY = 0.50,
        })

    _inEqCorner2Point = self:AddInput("Bottom Right Crop", "EqCorner2Point", {
        LINKID_DataType = "Point",
        INPID_InputControl = "OffsetControl",
        INPID_PreviewControl = "CrosshairControl",
        INP_DefaultX = 0.95,
        INP_DefaultY = 0.01,
        })

    -- Nitpick: It's not a % if the value is in the [0..1] range, and I don't even care!
    -- Gap == 0 ==> no gap between the EQ bars
    -- Gap == 1 ==> 100% gap, EQ bars not visible.
    _inEqGapPercentage = self:AddInput("Gap %", "EqGapPercentage", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.25,
        ICD_Center = 1,
        })

    _inEqStrokeWidth = self:AddInput("Stroke Width", "EqStrokeWidth", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinAllowed = 0.0,
        INP_MinScale = 0.0,
        INP_MaxScale = 0.01,
        INP_Default = 0.003,
        ICD_Center = 0.001,
        })

    _inEqFillAlpha = self:AddInput("Fill Alpha", "EqFillAlpha", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.5,
        ICD_Center = 1,
        })


    --
    -- AddOutput("User Visible Name", "InternalScriptName")
    -- It seems the first one is shown in menus, the second one in e.g. expressions.
    -- Using the same makes it easier to know the expression name to use.
    --

    _outImage = self:AddOutput("Output", "Output", {
        LINKID_DataType = "Image",
        LINK_Main = 1,
        })

    -- Nitpick: the unit is really dBFS (dB full signal) and not "dB" which is a _relative_ measure.
    -- Also, I'm annoyed that the CamelCasing makes that "Db" instead of "dB". Just saying.
    _outVuMeterDb = self:AddOutput("VuMeterDb", "VuMeterDb", {
        LINKID_DataType = "Number",
        })

    _outVuMeterLinear = self:AddOutput("VuMeterLinear", "VuMeterLinear", {
        LINKID_DataType = "Number",
        })
    _outVuMeterLinearMin = self:AddOutput("VuMeterLinearMin", "VuMeterLinearMin", {
        LINKID_DataType = "Number",
        })
    _outVuMeterLinearMax = self:AddOutput("VuMeterLinearMax", "VuMeterLinearMax", {
        LINKID_DataType = "Number",
        })

    _outEqBands = {}
    for idx, band in ipairs(EQ_BANDS) do
        local outName = string.format("EqBand%d", idx)
        local fuseOutput = self:AddOutput(outName, outName, {
            LINKID_DataType = "Number",
            })
        _outEqBands[idx] = fuseOutput
    end
end

function NotifyChanged(inp, param, time)
    -- print("@@ NotifyChanged", inp, param, time)

    if inp ~= nil and param ~= nil then
        if inp == _inWavFile then
            readGlobalFile(param.Value)
        elseif inp == _inWavOffsetSeconds then
            -- print("@@ NotifyChanged _inWavOffsetSeconds to " .. param.Value)
            _wavOffsetSeconds = param.Value
        end
    end

end

function Process(req)
    local startTime = os.clock()
    -- It seems a CT_SourceTools inherits Width/Height/Scale properties whereas CT_Tool does not.
    -- This part here is mirrored from the Fuse SourceTool Sample.
	local realWidth = Width;
	local realHeight = Height;

	-- We'll handle proxy ourselves
	Width = Width / Scale
	Height = Height / Scale
	Scale = 1

	local outImgAttrs = {
		IMG_Document = self.Comp,
		{ IMG_Channel = "Red", },
		{ IMG_Channel = "Green", },
		{ IMG_Channel = "Blue", },
		{ IMG_Channel = "Alpha", },
		IMG_Width = Width,
		IMG_Height = Height,
		IMG_XScale = XAspect,
		IMG_YScale = YAspect,
		IMAT_OriginalWidth = realWidth,
		IMAT_OriginalHeight = realHeight,
		IMG_Quality = not req:IsQuick(),
		IMG_MotionBlurQuality = not req:IsNoMotionBlur(),
		}

	if not req:IsStampOnly() then
		outImgAttrs.IMG_ProxyScale = 1
	end

	if SourceDepth ~= 0 then
		outImgAttrs.IMG_Depth = SourceDepth
	end

    local isPreCalc = req:IsPreCalc()   -- PreCalc -> Process with NoData Image
    if isPreCalc then
        -- PreCalcProcess should only return image *information*, no actual data.
        -- Documentation: https://www.steakunderwater.com/VFXPedia/96.0.243.189/index1c2b.html
        outImgAttrs.IMG_NoData = true
    end

    local outImg = Image(outImgAttrs)

    if not isPreCalc then
        outImg:Fill(Pixel({R=0,G=0,B=0,A=0}))
    end

    -- get the frame rate of the comp set in the preferences
    local frameRate = self.Comp:GetPrefs("Comp.FrameFormat.Rate")
    _globalStart = self.Comp:GetPrefs("Comp.Unsorted.GlobalStart")

    local frameIndex = req.Time
    if frameIndex < 0 then
        -- This does happen if an Adjustment Clip is extended on the left.
        print("@@ Process, Warning frameIndex " .. frameIndex .. " is negative.")
        frameIndex = 0
    end

    if _loadedWavSamples == nil then
        local infile = _inWavFile:GetValue(req).Value
        print("@@ Process loading " .. infile)
        readGlobalFile(infile)
    end

    local numSamples = numLoadedWavSamples()
    print("@@ Process  #" .. frameIndex .. ", start " .. _globalStart .. ", fps " .. frameRate .. ", " .. numSamples .. " samples", isPreCalc)
    if not isPreCalc then
        --  DEBUG: dump_object("", self.Comp:GetPrefs())
    end

    if _wavOffsetSeconds < 0 then
        _wavOffsetSeconds = _inWavOffsetSeconds:GetValue(req).Value
        print("@@ WAV Offset " .. _wavOffsetSeconds .. " seconds @ " .. _loadedSampleRate .. "/s")
    end

    if numSamples > 0 then
        computeVuMeter(req, frameIndex, frameRate, numSamples)

        if not isPreCalc then
            local inLiveMonitor     = _inVuMeterLiveMonitor:GetValue(req).Value
            local inDisplayWaveform = _inDisplayWaveform:GetValue(req).Value
            local inDisplayEqBars = _inDisplayEqBars:GetValue(req).Value

            if inDisplayWaveform == 1 then
                drawWaveform(req, outImg, frameIndex, frameRate, numSamples)
            end
            if inDisplayEqBars == 1 then
                _computeEqBands(req, frameIndex, frameRate, numSamples)
                drawEqBands(req, outImg)
            end

            if inLiveMonitor == 1 then
                _inInfoVuMeterLiveMonitor:SetAttrs({
                    LINKS_Name = string.format("Monitor: %.2f dB, %.3f < %.2f < %.3f linear",
                        _vuMeterDbValue,
                        _vuMeterLinearMin, _vuMeterLinearValue, _vuMeterLinearMax),
                    LBLC_LabelColor = 3,
                })
                local midSampleIndex = toSampleIndex(frameIndex, frameRate)
                _inInfoVuMeterLiveMonitor2:SetAttrs({
                    LINKS_Name = string.format("%d = %d@%d fps + %.2fs@%d/s",
                        midSampleIndex,
                        frameIndex, frameRate,
                        _wavOffsetSeconds, _loadedSampleRate ),
                    LBLC_LabelColor = 3,
                })

            end
        end
    end

    _outImage:Set(req, outImg)
    _outVuMeterDb:Set(req, Number(_vuMeterDbValue))
    _outVuMeterLinear:Set(req, Number(_vuMeterLinearValue))
    _outVuMeterLinearMin:Set(req, Number(_vuMeterLinearMin))
    _outVuMeterLinearMax:Set(req, Number(_vuMeterLinearMax))
    for idx, outEqBand in ipairs(_outEqBands) do
        local value = 0.0
        if _eqBands ~= nil then
            value = _eqBands[idx]
        end
        outEqBand:Set(req, Number(value))
    end
    print("@@   Process " .. frameIndex .. ", " .. 1000 * (os.clock() - startTime) .. " ms")
end

function computeVuMeter(req, frameIndex, frameRate, numSamples)
    -- Caller should not invoke this if _loadedWavSamples or _loadedSampleRate are nil/0. We don't check again here.
    -- print("@@ computeVuMeter ", frameIndex, frameRate, numSamples)

    if frameIndex == _vuMeterLastFrameIndex then
        -- Avoid computing the same values twice
        return
    end

    -- Smoothing: 0 = instant/0% smoothing; 1 = 100% smoothing (won't change)
    local inVuMeterSmoothingFactorDn = _inVuMeterSmoothingFactorDown:GetValue(req).Value
    local inVuMeterSmoothingFactorUp = _inVuMeterSmoothingFactorUp:GetValue(req).Value
    local inVuMeterDurationSeconds = _inVuMeterDurationSeconds:GetValue(req).Value

    -- The index of the sample in the middle
    local midSampleIndex = toSampleIndex(frameIndex, frameRate)
    local endSampleIndex = math.min(midSampleIndex + inVuMeterDurationSeconds * _loadedSampleRate, numSamples) - 1

    _vuMeterDbValue, _vuMeterLinearValue = _computeVuMeter(
        _vuMeterLinearValue, midSampleIndex, endSampleIndex,
        inVuMeterSmoothingFactorDn, inVuMeterSmoothingFactorUp)
    if frameIndex == _globalStart then
        -- Reset min/max if starting to play from the beginning.
        _vuMeterLinearMin = _vuMeterLinearValue
        _vuMeterLinearMax = _vuMeterLinearValue
    else
        _vuMeterLinearMin = math.min(_vuMeterLinearMin, _vuMeterLinearValue)
        if _vuMeterLinearValue >= _vuMeterLinearMax then
            _vuMeterLinearMax = _vuMeterLinearValue
        else
            -- smoothing decay of the max value towards current value
            -- TBD revisit this decay to be time-based, or make a it param. Current one is nice at 30 fps.
            local smoothingDecay = 0.99
            _vuMeterLinearMax = smoothingDecay * _vuMeterLinearMax + (1 - smoothingDecay) * _vuMeterLinearValue
        end
    end
    _vuMeterLastFrameIndex = frameIndex
end

function _computeVuMeter(linearValue, startIndex, endIndex, smoothingFactorDown, smoothingFactorUp)
    local lenSamples = endIndex - startIndex + 1
    -- print("@@ _computeVuMeter from " .. startIndex .. " to " .. endIndex .. ", len " .. lenSamples)
    if lenSamples <= 0 then
        return -96.0, 0.0
    end

    local sumSquares = 0.0

    for i = startIndex, endIndex do
        local normalized = _loadedWavSamples[i] / MAX_INT16
        sumSquares = sumSquares + (normalized * normalized)
    end

    local rms = math.sqrt(sumSquares / lenSamples)
    if rms > linearValue then
        linearValue = smoothingFactorUp   * linearValue + (1 - smoothingFactorUp  ) * rms
    else
        linearValue = smoothingFactorDown * linearValue + (1 - smoothingFactorDown) * rms
    end

    local currentDb = -96.0
    if linearValue > 0.00001 then
        currentDb = 20 * math.log10(linearValue)
    end

    return currentDb, linearValue
end

function _computeEqBands(req, frameIndex, frameRate, numSamples)
    if frameIndex == _eqBandsLastFrameIndex then
        -- Avoid computing the same values twice
        return
    end

    -- Smoothing: 0 = instant/0% smoothing; 1 = 100% smoothing (won't change)
    local inEqSmoothingFactorDn = _inEqSmoothingFactorDown:GetValue(req).Value
    local inEqSmoothingFactorUp = _inEqSmoothingFactorUp:GetValue(req).Value
    local inEqDurationSeconds = _inEqDurationSeconds:GetValue(req).Value

    -- The index of the sample in the middle
    local midSampleIndex = toSampleIndex(frameIndex, frameRate)
    local endSampleIndex = math.min(midSampleIndex + inEqDurationSeconds * _loadedSampleRate, numSamples) - 1
    _updateEqBands(midSampleIndex, endSampleIndex, inEqSmoothingFactorDn, inEqSmoothingFactorUp)

    _eqBandsLastFrameIndex = frameIndex
end

function _initEqBands()
    --- Calculates Biquad Bandpass coefficients for each band
    -- Must be called once before processing begins once sample rate is known
    if _loadedSampleRate == 0 then
        return
    end

    -- Quality factor. 1.0 provides a good balance/overlap for visualizers
    local Q = 1.0

    -- Prepare the global result array
    _eqBands = {}

    for idx, band in ipairs(EQ_BANDS) do
        local omega = 2 * math.pi * band.f0 / _loadedSampleRate
        local alpha = math.sin(omega) / (2 * Q)
        local cos_w = math.cos(omega)

        -- Standard Biquad Bandpass coefficients
        local b0 = alpha
        local b1 = 0
        local b2 = -alpha
        local a0 = 1 + alpha
        local a1 = -2 * cos_w
        local a2 = 1 - alpha

        -- Normalize coefficients by dividing by a0
        band.b0 = b0 / a0
        band.b1 = b1 / a0
        band.b2 = b2 / a0
        band.a1 = a1 / a0
        band.a2 = a2 / a0

        -- Keep filter history (persistent state between video frames to prevent popping)
        band.z1 = 0.0
        band.z2 = 0.0
        band.visual_linear = 0.0

        _eqBands[idx] = 0.0
    end
    -- print("@@ _initEqBands DONE ", _eqBands, #_eqBands)
end

function _updateEqBands(startIndex, endIndex, smoothingFactorDown, smoothingFactorUp)
    -- Processes an audio chunk and updates the linear volume levels for every band
    -- Caller should not invoke this if _loadedWavSamples or _loadedSampleRate are nil/0. We don't check again here.
    -- Fills the global _eqBands array (initialized by _initEqBands)

    if _eqBands == nil then
        _initEqBands()
    end

    local lenSamples = endIndex - startIndex + 1
    if lenSamples <= 0 or _eqBands == nil then
        return
    end

    -- Process every band independently
    for idx, band in ipairs(EQ_BANDS) do
        local b0, b2, a1, a2 = band.b0, band.b2, band.a1, band.a2
        local z1, z2 = band.z1, band.z2
        local sumSquares = 0.0

        -- Run Direct Form II Transposed IIR Filter Loop
        for i = startIndex, endIndex do
            local x = _loadedWavSamples[i] / MAX_INT16 -- Normalize input

            -- Filter processing
            local y = (b0 * x) + z1
            z1 = (-a1 * y) + z2
            z2 = (b2 * x) - (a2 * y)

            sumSquares = sumSquares + (y * y)
        end

        -- Save history state back to the band for the next video frame
        band.z1 = z1
        band.z2 = z2

        -- Calculate RMS energy of this specific frequency band
        local rms = math.sqrt(sumSquares / lenSamples)

        -- Boost the visual gain slightly because splitting audio into bands reduces individual band amplitudes
        rms = rms * 2.5
        if rms > 1.0 then
            rms = 1.0
        end

        -- Apply smoothing on the EQ bars
        local value = band.visual_linear
        if rms > value then
            value = (smoothingFactorUp   * value) + ((1 - smoothingFactorUp  ) * rms)
        else
            value = (smoothingFactorDown * value) + ((1 - smoothingFactorDown) * rms)
        end
        band.visual_linear = value
        _eqBands[idx] = value
    end
end

function drawEqBands(req, outImg)
    if _eqBands == nil then
        return
    end

    -- All coordinates are in the 0..1 coordinate system, where 0..1 matches the width.
    -- Pixels are "square", which means the height is not 0..1, but from 0 up to PxH / PxW.
    local imgPxW = outImg.Width
    local imgPxH = outImg.Height
    local ratioY = imgPxH / imgPxW

    local inEqCorner1Point = _inEqCorner1Point:GetValue(req)
    local inEqCorner2Point = _inEqCorner2Point:GetValue(req)
    local inEqGapPercentage = _inEqGapPercentage:GetValue(req).Value
    local inEqStrokeWidth = _inEqStrokeWidth:GetValue(req).Value
    local inEqFillAlpha = _inEqFillAlpha:GetValue(req).Value

    local areaX1 = math.min(inEqCorner1Point.X, inEqCorner2Point.X)
    local areaX2 = math.max(inEqCorner1Point.X, inEqCorner2Point.X)
    local areaY1 = math.min(inEqCorner1Point.Y, inEqCorner2Point.Y) * ratioY
    local areaY2 = math.max(inEqCorner1Point.Y, inEqCorner2Point.Y) * ratioY
    local areaW = areaX2 - areaX1
    local areaH = areaY2 - areaY1

    local thickness = inEqStrokeWidth
    local fillAlpha = inEqFillAlpha

    local precision = 8  -- quality/amount of oversampling (8 in example)
    local ic = ImageChannel(outImg, precision)
    local fs = FillStyle()
    local cs_outline = ChannelStyle()
    local cs_filled = ChannelStyle()
    local round_corners = 0
    ic:SetStyleFill(fs)
    cs_outline.Color = Pixel({R = 1, G = 1, B = 1, A = 1})  -- make it params
    cs_filled.Color  = Pixel({R = fillAlpha, G = fillAlpha, B = fillAlpha, A = fillAlpha})
    -- Other options: cs.BlurType, cs.SoftessX/Y/Glow/Blend (see Text+ for example)

    -- Reminder: all shape coordinates are in [0..1] range
    local num_bands = #_eqBands
    -- gap between bands
    local gw = areaW * inEqGapPercentage / math.max(1, (num_bands - 1))
    -- width of each band
    -- TBD: consider changing band width with frequency (larger for lower frequencies)
    local xw = (areaW * (1 - inEqGapPercentage)) / num_bands
    local y1 = areaY1
    local y2 = areaY2

    -- Add all filled rectangles
    local sh = Shape()
    local x1 = areaX1
    for idx, visualLinear in ipairs(_eqBands) do
        local x2 = x1 + xw
        local y3 = y1 + areaH * visualLinear

        sh:AddRectangle(x1, x2, y1, y3, round_corners, precision)
        -- next band
        x1 = x2 + gw
    end
    ic:ShapeFill(sh)
    if self.Status == "OK" then
        ic:PutToImage("CM_Merge", cs_filled)
    end

    -- Add all outline rectangles
    sh = Shape()
    x1 = areaX1
    for idx, visualLinear in ipairs(_eqBands) do
        local x2 = x1 + xw
        sh:AddRectangle(x1, x2, y1, y2, round_corners, precision)
        -- next band
        x1 = x2 + gw
    end
    sh = sh:OutlineOfShape(thickness, "OLT_Solid", "OJT_Round", precision, "SWM_Normal", precision)
    ic:ShapeFill(sh)
    if self.Status == "OK" then
        ic:PutToImage("CM_Merge", cs_outline)
    end

end

function drawWaveform(req, outImg, frameIndex, frameRate, numSamples)
    -- Caller should not invoke this if _loadedWavSamples or _loadedSampleRate are nil/0. We don't check again here.

    -- All coordinates are in the 0..1 coordinate system, where 0..1 matches the width.
    -- Pixels are "square", which means the height is not 0..1, but from 0 up to PxH / PxW.
    local imgPxW = outImg.Width
    local imgPxH = outImg.Height
    local ratioY = imgPxH / imgPxW
    local scaleX = 1 / imgPxW -- converts from pixels to [0..1] coordinates

    local inWaveformShape = _inWaveformShape:GetValue(req).Value
    -- How many seconds we represent on the X axis
    local inWaveformSecondsX = _inWaveformSecondsX:GetValue(req).Value
    local inWaveformCorner1Point = _inWaveformCorner1Point:GetValue(req)
    local inWaveformCorner2Point = _inWaveformCorner2Point:GetValue(req)
    local inWaveformStrokeWidth = _inWaveformStrokeWidth:GetValue(req).Value
    local inWaveformFillAlpha = _inWaveformFillAlpha:GetValue(req).Value
    local inWaveformAmpliFactor = _inWaveformAmpliFactor:GetValue(req).Value
    local inDisplayAmplitude = _inDisplayAmplitude:GetValue(req).Value

    local areaX1 = math.min(inWaveformCorner1Point.X, inWaveformCorner2Point.X)
    local areaX2 = math.max(inWaveformCorner1Point.X, inWaveformCorner2Point.X)
    local areaY1 = math.min(inWaveformCorner1Point.Y, inWaveformCorner2Point.Y) * ratioY
    local areaY2 = math.max(inWaveformCorner1Point.Y, inWaveformCorner2Point.Y) * ratioY
    local areaW = areaX2 - areaX1
    local areaPxW = math.floor(areaW * imgPxW)
    local areaH = areaY2 - areaY1

    if areaPxW < 2 then
        return
    end

    local thickness = inWaveformStrokeWidth
    local fillAlpha = inWaveformFillAlpha
    local x0 = areaX1
    local y0 = (areaY1 + areaY2) / 2
    local areaPxW1 = areaPxW - 1
    local fullWaveHeightY = areaH
    local halfWaveHeightY = areaH / 2
    if inWaveformShape == WaveformShape_HalfWave then
        y0 = areaY1
        halfWaveHeightY = fullWaveHeightY
    end

    if inWaveformAmpliFactor > 0 and inWaveformAmpliFactor <= 1 then
        -- inWaveformAmpliFactor is the % to _reduce_ the amplitude when the vu-meter is 0.
        local reduction = 1 - _vuMeterLinearValue / math.max(_vuMeterLinearMax, 0.1)
        halfWaveHeightY = halfWaveHeightY - halfWaveHeightY * inWaveformAmpliFactor * reduction
    end

    -- The index of the sample in the middle
    local midSampleIndex = toSampleIndex(frameIndex, frameRate)
    -- We display inWaveformSecondsX numbers of seconds on the img width,
    -- so half before and half after. Convert that to number of samples.
    local numSamplesPerPx = inWaveformSecondsX * _loadedSampleRate / areaPxW1
    local numHalfSamples  = inWaveformSecondsX * _loadedSampleRate / 2
    local numSamplesPerPx1 = numSamplesPerPx
    -- print("@@ drawWaveform: frameIndex " .. frameIndex .. "/" .. frameRate ..
    --         " + " .. _wavOffsetSeconds .. " @ " .. _loadedSampleRate .. "/s = " .. midSampleIndex ..
    --         ", areaW " .. areaW .. " = " .. areaPxW1 .. "px, " .. numSamplesPerPx .. " sample/px" )

    local precision = 8  -- quality/amount of oversampling (8 in example)
    local ic = ImageChannel(outImg, precision)
    local fs = FillStyle()
    local cs_outline = ChannelStyle()
    local cs_filled = ChannelStyle()
    ic:SetStyleFill(fs)
    cs_outline.Color = Pixel({R = 1, G = 1, B = 1, A = 1})  -- make it params
    cs_filled.Color  = Pixel({R = fillAlpha, G = fillAlpha, B = fillAlpha, A = fillAlpha})
    -- Other options: cs.BlurType, cs.SoftessX/Y/Glow/Blend (see Text+ for example)

    local numSamples1 = numSamples - 1
    local sh_outline
    local sh_filled
    local xCoords = {}
    local maxYCoords = {}
    local minYCoords = {}

    if inDisplayAmplitude == 1 then
        sh_outline = Shape()
        local y = halfWaveHeightY
        sh_outline:MoveTo(areaX1, y0 + y)
        sh_outline:LineTo(areaX2, y0 + y)
        if inWaveformShape ~= WaveformShape_HalfWave then
            sh_outline:MoveTo(areaX1, y0 - y)
            sh_outline:LineTo(areaX2, y0 - y)
        end
        sh_outline = sh_outline:OutlineOfShape(thickness, "OLT_Solid", "OJT_Round", precision, "SWM_Normal", precision)
        ic:ShapeFill(sh_outline)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_outline)
        end
    end

    if inWaveformShape == WaveformShape_HalfWave then
        for px = 0, areaPxW1 do
            local x = x0 + px * scaleX

            local startSampleIndex = midSampleIndex   + px * numSamplesPerPx - numHalfSamples
            local endSampleIndex   = startSampleIndex + numSamplesPerPx1
            startSampleIndex = math.floor(math.max(0, math.min(startSampleIndex, numSamples1)))
            endSampleIndex   = math.floor(math.max(0, math.min(endSampleIndex  , numSamples1)))

            -- Scan the single-pixel window to find the absolute extremes
            local maxSample = 0.0
            for s = startSampleIndex, endSampleIndex do
                local sample = _loadedWavSamples[s] / MAX_INT16
                sample = math.abs(sample)
                if sample > maxSample then
                    maxSample = sample
                end
            end

            -- Map to screen coordinates and cache them
            xCoords[px] = x
            maxYCoords[px] = y0 + maxSample * halfWaveHeightY
        end

        sh_filled = Shape()
        sh_filled:LineTo(areaX1, y0)
        for px = 0, areaPxW1 do
            sh_filled:LineTo(xCoords[px], maxYCoords[px])
        end
        sh_filled:LineTo(areaX2, y0)
        sh_outline = sh_filled:OutlineOfShape(thickness, "OLT_Solid", "OJT_Round", precision, "SWM_Normal", precision)
        sh_filled:Close()

        ic:ShapeFill(sh_filled)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_filled)
        end
        ic:ShapeFill(sh_outline)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_outline)
        end

    elseif inWaveformShape == WaveformShape_MirrorWave then
        for px = 0, areaPxW1 do
            local x = x0 + px * scaleX

            local startSampleIndex = midSampleIndex   + px * numSamplesPerPx - numHalfSamples
            local endSampleIndex   = startSampleIndex + numSamplesPerPx1
            startSampleIndex = math.floor(math.max(0, math.min(startSampleIndex, numSamples1)))
            endSampleIndex   = math.floor(math.max(0, math.min(endSampleIndex  , numSamples1)))

            -- Scan the single-pixel window to find the absolute extremes
            local maxSample = 0.0
            for s = startSampleIndex, endSampleIndex do
                local sample = _loadedWavSamples[s] / MAX_INT16
                sample = math.abs(sample)
                if sample > maxSample then
                    maxSample = sample
                end
            end

            -- Map to screen coordinates and cache them
            xCoords[px] = x
            maxYCoords[px] = y0 + maxSample * halfWaveHeightY
        end

        sh_filled = Shape()
        sh_filled:LineTo(areaX1, y0)
        for px = 0, areaPxW1 do
            sh_filled:LineTo(xCoords[px], maxYCoords[px])
        end
        sh_filled:LineTo(areaX2, y0)
        sh_outline = sh_filled:OutlineOfShape(thickness, "OLT_Solid", "OJT_Round", precision, "SWM_Normal", precision)
        sh_filled:Close()

        ic:ShapeFill(sh_filled)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_filled)
        end
        ic:ShapeFill(sh_outline)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_outline)
        end

        local mat = Matrix4()
        mat:Scale(1, -1, 1)
        mat:Move(0, y0 * 2, 0)
        sh_filled  = sh_filled:TransformOfShape(mat)
        sh_outline = sh_outline:TransformOfShape(mat)
        ic:ShapeFill(sh_filled)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_filled)
        end
        ic:ShapeFill(sh_outline)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_outline)
        end

    else
        -- Renders WaveformShape_SignedWave by default
        for px = 0, areaPxW1 do
            local x = x0 + px * scaleX

            local startSampleIndex = midSampleIndex   + px * numSamplesPerPx - numHalfSamples
            local endSampleIndex   = startSampleIndex + numSamplesPerPx1
            startSampleIndex = math.floor(math.max(0, math.min(startSampleIndex, numSamples1)))
            endSampleIndex   = math.floor(math.max(0, math.min(endSampleIndex  , numSamples1)))

            -- Scan the single-pixel window to find the absolute extremes
            local minSample = 1.0
            local maxSample = -1.0
            for s = startSampleIndex, endSampleIndex do
                local sample = _loadedWavSamples[s] / MAX_INT16
                if sample > maxSample then
                    maxSample = sample
                end
                if sample < minSample then
                    minSample = sample
                end
            end

            -- Map to screen coordinates and cache them
            xCoords[px] = x
            maxYCoords[px] = y0 + maxSample * halfWaveHeightY
            minYCoords[px] = y0 + minSample * halfWaveHeightY
        end

        sh_filled = Shape()
        sh_filled:MoveTo(xCoords[0], maxYCoords[0])
        for px = 1, areaPxW1 do
            sh_filled:LineTo(xCoords[px], maxYCoords[px])
        end
        for px = areaPxW1, 0, -1 do
            sh_filled:LineTo(xCoords[px], minYCoords[px])
        end
        sh_outline = sh_filled:OutlineOfShape(thickness, "OLT_Solid", "OJT_Round", precision, "SWM_Normal", precision)
        sh_filled:Close()

        ic:ShapeFill(sh_filled)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_filled)
        end
        ic:ShapeFill(sh_outline)
        if self.Status == "OK" then
            ic:PutToImage("CM_Merge", cs_outline)
        end
   end

end

function numLoadedWavSamples()
    if _loadedWavSamples == nil then
        return 0
    end
    -- We only support 16-bit mono samples data
    return ffi.sizeof(_loadedWavSamples) / 2
end

function toSampleIndex(frameIndex, frameRate)
    -- Returns the sample index matching that frameIndex or 0 if invalid.
    -- This does not check for index max bound.
    if _loadedWavSamples == nil or frameIndex < 0 then
        return _wavOffsetSeconds * _loadedSampleRate
    end
    local seconds = frameIndex / frameRate
    return math.floor((_wavOffsetSeconds + seconds) * _loadedSampleRate)
end

function readGlobalFile(filename)
    -- Reset global state
    _vuMeterLastFrameIndex = -1
    _eqBandsLastFrameIndex = -1

    local msg = _readFile(filename)
    if msg == nil then
        _loadedFileStatus = string.format("%d samples, %d/s", numLoadedWavSamples(), _loadedSampleRate)
        _loadedFileName = filename
        _inInfoFileName:SetAttrs({
            LINKS_Name = getBasename(_loadedFileName),
            LBLC_LabelColor = 3,
        })
        _inInfoFileStatus:SetAttrs({
            LINKS_Name = _loadedFileStatus,
            LBLC_LabelColor = 3,
        })
        return
    else
        print("@@ _readFile error: ", msg)
        _loadedFileStatus = msg
        _loadedFileName = ""
        _inInfoFileName:SetAttrs({
            LINKS_Name = "No Audio loaded",
            LBLC_LabelColor = 3,
        })
        _inInfoFileStatus:SetAttrs({
            LINKS_Name = _loadedFileStatus,
            LBLC_LabelColor = 3,
        })
    end
end

function _readFile(filename)
    -- Returns an error string or nil on case of success.
    -- Sets globals _loadedWavFormat and _loadedWavSamples on success.

    -- Comp:MapPath is apparently used to resolve Project Settings > Path Mapping.
    local filepath = self.Comp:MapPath(filename)
    print("@@ _readFile " .. filepath)
    local file, err = io.open(filepath, "rb")
    if not file then
        return "Could not open file: " .. tostring(err)
    end

    local riff_chunk = file:read(12)
    if not riff_chunk or #riff_chunk < 12 then
        file:close()
        return "File too small"
    end
    local riff = ffi.cast("WAV_RIFF_Header*", riff_chunk)

    if ffi.string(riff.chunkID, 4) ~= "RIFF" or ffi.string(riff.format, 4) ~= "WAVE" then
        file:close()
        return "Not a valid WAV file"
    end

    local channels = 0
    local sample_rate = 0
    local bits_per_sample = 0

    -- Parse all chunks until we find "fmt", ignore any other ones.
    while true do
        local chunk_header = file:read(8)
        -- print("@@ _readFile " .. "read CHUNK " .. #chunk_header .. " bytes")
        if not chunk_header or #chunk_header < 8 then
            break
        end

        local chunk = ffi.cast("WAV_Chunk_Header*", chunk_header)
        local chunk_id = ffi.string(chunk.chunkID, 4)
        local chunk_size = chunk.chunkSize
        print("@@ _readFile Chunk " .. chunk_id .. ", size " .. chunk_size)

        if chunk_id == "fmt " then
            -- Rewind 8 bytes and read the whole format chunk structure
            file:seek("cur", -8)
            local fmt_data = file:read(math.max(chunk_size + 8, 24))
            local fmt = ffi.cast("WAV_FMT_Chunk*", fmt_data)
            _loadedWavFormat = fmt
            _loadedSampleRate = fmt.sampleRate
            _wavOffsetSeconds = -1
            _initEqBands()

            channels = fmt.numChannels
            sample_rate = fmt.sampleRate
            bits_per_sample = fmt.bitsPerSample

            print("@@ _readFile: channels " .. channels .. ", sample_rate " .. sample_rate .. ", bits_per_sample " .. bits_per_sample )

            -- Validation: we limit ourselves to 16-bit PCM LE, mono or stereo.
            if fmt.audioFormat ~= 1 then
                file:close()
                return "Only uncompressed PCM supported"
            end
            if bits_per_sample ~= 16 then
                file:close()
                return "Only 16-bit supported"
            end
            if channels ~= 1 and channels ~= 2 then
                file:close()
                return "Only Mono/Stereo supported"
            end
        elseif chunk_id == "data" and channels ~= 0 then
            -- Only accept data _after_ the fmt chunk
            local numBytes = chunk_size
            print("@@ _readFile: DATA numBytes " .. numBytes )
            local raw_bytes = file:read(numBytes)
            file:close()

            if not raw_bytes or #raw_bytes < numBytes then
                return "Data chunk size mismatch or truncated file"
            end

            -- Cast raw string data to a C-array of signed 16-bit integers
            local int16_ptr = ffi.cast("int16_t*", raw_bytes)
            local total_input_samples = numBytes / 2

            local out_samples
            local total_mono_samples

            if channels == 1 then
                total_mono_samples = total_input_samples
                -- Allocate native memory array for LuaJIT
                out_samples = ffi.new("int16_t[?]", total_mono_samples)
                -- Blit memory instantly via C-copy
                ffi.copy(out_samples, int16_ptr, numBytes)
                print("@@ _readFile: MONO loaded " .. total_mono_samples .. " samples" )
            else
                -- Stereo mix down to mono
                total_mono_samples = total_input_samples / 2
                -- Allocate native memory array for LuaJIT
                out_samples = ffi.new("int16_t[?]", total_mono_samples)

                -- Average all channel samples
                for i = 0, total_mono_samples - 1 do
                    local left = int16_ptr[i * 2]
                    local right = int16_ptr[i * 2 + 1]
                    -- Average channels for mono
                    out_samples[i] = math.floor((left + right) / 2)
                end
                print("@@ _readFile: STEREO loaded " .. total_mono_samples .. " samples" )
            end

            -- Keep a reference on the mono sample data.
            _loadedWavSamples = out_samples
            print("@@ _readFile: _loadedWavSamples " .. numLoadedWavSamples() .. " samples" )
            -- We already closed the file above. Return no error
            return nil
        else
            -- Skip unknown chunks
            file:seek("cur", chunk_size)
        end
    end

    file:close()
    return "WAV format or data not found"
end

-- Get the base filename from a filepath
function getBasename(filePath)
    return string.match(filePath, "([^/\\]+)$")
end

function dump_object(prefix, obj)

    if (type(obj)) == "cdata" then
        -- Get the internal type ID of the cdata object
        local ctype_id = ffi.typeof(obj)

        print(prefix .. "--- cdata FFI Struct Fields ---", ctype_id)
        -- Reflect into the struct members using typeinfo
        local i = 0
        local unknown = 0
        while true do
            local info = ffi.typeinfo(ctype_id, i)
            if not info then break end
            if info.name then
                print(prefix .. string.format("  [%d] Field: %s", i, info.name))
                unknown = 0
            else
                print(prefix .. string.format("  [%d] ??: ", i), info)
                if type(info) == "table" then
                    dump_object(prefix .. "> ", info)
                end
                unknown = unknown + 1
                if unknown >= 2 then break end
            end
            i = i + 1
        end
        return
    end

    if type(obj) ~= "table" then
        print(prefix .. "Not a standard Lua object/table. Type is: " .. type(obj))
        return
    end

    print(prefix .. "--- Instance Fields ---")
    for key, value in pairs(obj) do
        print(prefix .. string.format("  %s (%s)", tostring(key), type(value)))
        if type(value) == "table" then
            dump_object(prefix .. "> ", value)
        end
    end

    -- Look for methods/inherited fields in the metatable
    local mt = getmetatable(obj)
    if mt and mt.__index then
        print(prefix .. "--- Inherited Fields & Methods (__index) ---")
        local target = mt.__index
        -- If __index is a table, we can loop through it
        if type(target) == "table" then
            for key, value in pairs(target) do
                print(prefix .. string.format("  %s (%s)", tostring(key), type(value)))
            end
        elseif type(target) == "function" then
            print(prefix .. "  __index is a function; fields cannot be listed dynamically.")
        end
    end
end
